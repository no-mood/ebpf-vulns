From a03568c0c1e28dfe27ad5b06c78a6cf875cd17c5 Mon Sep 17 00:00:00 2001
From: mood <74420740+no-mood@users.noreply.github.com>
Date: Tue, 22 Jul 2025 20:38:19 +0200
Subject: [PATCH] feat(5.45 invfmtstr): Supplying an unknown or invalid
 conversion specification; an invalid combination of flag character,
 precision, length modifier, conversion specifier; or a number and type of
 arguments to a formatted IO function that do not match the conversion
 specifiers in the format string.

---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 34 ++++++++++++++++++++++++++-
 1 file changed, 33 insertions(+), 1 deletion(-)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..0b5e0c0 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -374,6 +374,14 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 				       struct header_pointers *hdr)
 {
 	hdr->eth = data;
+
+	/* VULN 5.45 - Type mismatch in format string
+	 * %s expects a string pointer, but receives a long integer.
+	 * UB 160: Invalid conversion specification.
+	 * Output is empty or garbage; verifier does not block, but kernel cannot print the value.
+	 */
+	bpf_printk("Parsing packet at offset %s\n", (long)data);
+
 	if (hdr->eth + 1 > data_end)
 		return XDP_DROP;
 
@@ -382,8 +390,15 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 		hdr->ipv6 = NULL;
 
 		hdr->ipv4 = (void *)hdr->eth + sizeof(*hdr->eth);
-		if (hdr->ipv4 + 1 > data_end)
+		if (hdr->ipv4 + 1 > data_end) {
+			/* VULN 5.45 - Precision with hex conversion
+			 * Using precision (.5) with %x may produce undefined formatting.
+			 * UB 155: Precision with inappropriate conversion.
+			 */
+			bpf_printk("IPv4 bounds check failed: %.5x\n",
+				(unsigned int)((unsigned long)(hdr->ipv4 + 1) - (unsigned long)data_end));
 			return XDP_DROP;
+		}
 		if (hdr->ipv4->ihl * 4 < sizeof(*hdr->ipv4))
 			return XDP_DROP;
 		if (hdr->ipv4->version != 4)
@@ -393,6 +408,15 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 			return XDP_PASS;
 
 		hdr->tcp = (void *)hdr->ipv4 + hdr->ipv4->ihl * 4;
+
+		/* VULN 5.45 - Argument count mismatch
+		 * Format string has 3 conversion specifiers (%p, %d, %d) but only 2 arguments.
+		 * UB 156: Missing arguments for conversion specifiers.
+		 * Output: last specifier prints garbage or nothing.
+		 */
+		bpf_printk("IPv4 TCP header at %p, IHL=%d, proto=%d\n",
+			hdr->tcp, hdr->ipv4->ihl); // Missing third argument
+
 		break;
 	case ETH_P_IPV6:
 		hdr->ipv4 = NULL;
@@ -410,6 +434,14 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 			return XDP_PASS;
 
 		hdr->tcp = (void *)hdr->ipv6 + sizeof(*hdr->ipv6);
+
+		/* VULN 5.45 - Invalid flag combination
+		 * # flag is not valid with %d conversion specifier.
+		 * UB 157: Invalid flag with conversion specifier.
+		 * Output: formatting is undefined, may be ignored.
+		 */
+		bpf_printk("IPv6 nexthdr: %#d\n", hdr->ipv6->nexthdr);
+
 		break;
 	default:
 		/* XXX: VLANs will circumvent XDP SYN flood protection. */
-- 
