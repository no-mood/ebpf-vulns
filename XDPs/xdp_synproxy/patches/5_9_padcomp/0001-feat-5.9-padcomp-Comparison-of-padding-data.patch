From 645af9c0092fad88191251e2656e4594205fb2f7 Mon Sep 17 00:00:00 2001
From: Francesco Rollo <eferollo@gmail.com>
Date: Tue, 15 Jul 2025 23:32:45 +0000
Subject: [PATCH] feat(5.9 padcomp): Comparison of padding data

Signed-off-by: Francesco Rollo <eferollo@gmail.com>
---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 71 ++++++++++++++++++++++++++-
 1 file changed, 70 insertions(+), 1 deletion(-)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..425ca92 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -370,6 +370,26 @@ struct header_pointers {
 	__u16 tcp_len;
 };
 
+// [padcomp] This struct is designed to have padding bytes.
+struct __attribute__((aligned(8))) padded_config_data {
+	// 1 byte
+	char field_a;
+	// 4 bytes (aligned to 4 or 8). With 8 it will cause different padding.
+	int field_b;
+	// 1 byte
+	char field_c;
+	/*
+	 * Padding bytes layout:
+	 * - field_a at offset 0
+	 * - 3 bytes padding at offsets 1-3 (between field_a and field_b)
+	 * - field_b at offset 4-5-6-7
+	 * - field_c at offset 8
+	 * - 7 bytes padding at offsets 9-15 (after field_c for 8-byte alignment)
+	 * These padding bytes are uninitialized, can contain arbitrary data,
+	 * and using memcmp on full struct risks false mismatch due to padding.
+	 */
+};
+
 static __always_inline int tcp_dissect(void *data, void *data_end,
 				       struct header_pointers *hdr)
 {
@@ -830,7 +850,56 @@ int syncookie_xdp(struct xdp_md *ctx)
 	void *data_end = (void *)(long)ctx->data_end;
 	void *data = (void *)(long)ctx->data;
 	struct header_pointers hdr;
-	int ret;
+	int ret, cmp;
+
+	// 5.9 Comparison of padding data [padcomp]
+	struct padded_config_data config1 = {
+		.field_a = 0xaa,
+		.field_b = 0x12345678,
+		.field_c = 0xbb,
+	};
+
+	/*
+	 * Declare config2 without full aggregate initialization to let compiler
+	 * decide padding values. The eBPF verifier often zero-initializes stack
+	 * frames for security, which might mitigate the "unspecified value" aspect.
+	 * However, the rule is about the comparison itself.
+	 */
+	struct padded_config_data config2;
+
+	/*
+	 * Manually assign values to non-padding fields of config2.
+	 * This simulates a scenario where padding might legitimately differ
+	 * if not zeroed by system/compiler.
+	 */
+	config2.field_a = 0xaa;
+	config2.field_b = 0x12345678;
+	config2.field_c = 0xbb;
+
+	/*
+	 * Attempt to compare the two structures byte-by-byte using a built-in memcmp.
+	 * This comparison will include any padding bytes.
+	 * The verifier might issue a warning or reject if it detects a read from
+	 * uninitialized stack memory (if its zeroing isn't strong enough or it
+	 * detects a bypass).
+	 */
+	cmp = __builtin_memcmp(&config1, &config2, sizeof(struct padded_config_data));
+	if (cmp == 0) {
+		bpf_printk("[padcomp]: config1 and config2 matched (incl. padding)");
+		/*
+		 * Dummy action: increment a global counter if they "match".
+		 * This line is here just to ensure the comparison isn't optimized away.
+		 */
+		__u32 key = 0;
+		__u64 *val = bpf_map_lookup_elem(&values, &key);
+		if (val) {
+			bpf_printk("[padcomp]: XDP_DROP returned");
+			__sync_fetch_and_add(val, 1);
+			return XDP_DROP;
+		}
+	} else {
+		bpf_printk("[padcomp]: config1 and config2 did NOT match.");
+	}
 
 	ret = syncookie_part1(ctx, data, data_end, &hdr, true);
 	if (ret != XDP_TX)
-- 
