From 8a0d58dedcb157475c99a1dfed9a85e343170c32 Mon Sep 17 00:00:00 2001
From: mood <74420740+no-mood@users.noreply.github.com>
Date: Sun, 20 Jul 2025 16:51:34 +0200
Subject: [PATCH] feat(5.6b argcomp): Calling a function with the wrong number
 or type of arguments.

---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 28 +++++++++++++++++++++++++++
 1 file changed, 28 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..2060caa 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -370,6 +370,9 @@ struct header_pointers {
 	__u16 tcp_len;
 };
 
+/* Forward declaration for argcomp violation */
+void network_copy_helper();
+
 static __always_inline int tcp_dissect(void *data, void *data_end,
 				       struct header_pointers *hdr)
 {
@@ -422,9 +425,34 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 	if (hdr->tcp_len < sizeof(*hdr->tcp))
 		return XDP_DROP;
 
+	/* 5.6b [argcomp]: Calling functions with incorrect arguments - EXAMPLE 2
+	 *
+	 * Wrong number of arguments (UB 38). Based on 5.6 EXAMPLE 2
+	 * where copy function is defined to take two arguments but
+	 * called with three arguments.
+	 *
+	 * **Implementation Details:**
+	 * - Forward declaration `network_copy_helper()` is made without parameters
+	 * - The function is called with 3 arguments but will be defined to take only 2
+	 * - This simulates the "separate source file" scenario where the caller
+	 *   doesn't have the correct prototype in scope
+	 * - Demonstrates UB 38: "For a call to a function without a function
+	 *   prototype in scope, the number of arguments does not equal the number
+	 *   of parameters."
+	 */
+	__u8 extra_buf[ETH_ALEN] = {0};
+	network_copy_helper(hdr->eth->h_source, hdr->eth->h_dest, extra_buf);  // 3 args, but function takes 2
+	bpf_printk("[argcomp]: 5.6b - network copy called");
+
 	return XDP_TX;
 }
 
+/* Function definitions for argcomp violations - simulate "another source file" */
+/* 5.6b: Actually takes 2 arguments, but called with 3 above */
+void network_copy_helper(char *dst, char *src) {
+	__builtin_memcpy(dst, src, ETH_ALEN);
+}
+
 static __always_inline int tcp_lookup(void *ctx, struct header_pointers *hdr, bool xdp)
 {
 	struct bpf_ct_opts___local ct_lookup_opts = {
-- 
2.49.0

