From ebf0b6cf37aa50bb8fdde1853386259390171007 Mon Sep 17 00:00:00 2001
From: mood <74420740+no-mood@users.noreply.github.com>
Date: Sun, 20 Jul 2025 17:12:07 +0200
Subject: [PATCH] feat(5.6c argcomp): Calling a function with the wrong number
 or type of arguments.

---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 31 +++++++++++++++++++++++++++
 1 file changed, 31 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..76a0e08 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -370,6 +370,9 @@ struct header_pointers {
 	__u16 tcp_len;
 };
 
+/* Forward declaration for argcomp violation */
+void debug_print_helper();
+
 static __always_inline int tcp_dissect(void *data, void *data_end,
 				       struct header_pointers *hdr)
 {
@@ -422,9 +425,37 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 	if (hdr->tcp_len < sizeof(*hdr->tcp))
 		return XDP_DROP;
 
+	/* 5.6c [argcomp]: Calling functions with incorrect arguments - EXAMPLE 3
+	 *
+	 * Function with variable arguments called without proper prototype (UB 39).
+	 * Based on 5.6 EXAMPLE 3 where buginf function is defined to take
+	 * variable number of arguments but declared in another file with no prototype.
+	 *
+	 * **Implementation Details:**
+	 * - Forward declaration `debug_print_helper()` is made without parameters
+	 * - The function is called with format string and arguments (like printf)
+	 * - The actual function definition DOES support variable arguments
+	 * - But the caller doesn't have the proper prototype in scope to know this
+	 * - Demonstrates UB 39: "For a call to a function without a function prototype
+	 *   in scope where the function is defined with a function prototype, either
+	 *   the prototype ends with an ellipsis or the types of the arguments after
+	 *   promotion are not compatible with the types of the parameters."
+	 */
+	__u32 port_val = bpf_ntohs(hdr->tcp->source);
+	debug_print_helper("Port value: %u at line %d", port_val, __LINE__);  // Looks like printf
+	bpf_printk("[argcomp]: 5.6c - debug print called");
+
 	return XDP_TX;
 }
 
+/* Function definitions for argcomp violations - simulate "another source file" */
+/* 5.6c: Actually is variadic like buginf, but caller doesn't know (no prototype in scope) */
+void debug_print_helper(const char *fmt, ...) {
+	// In eBPF we can't use va_list properly, so we simulate the concept
+	// The point is that this function IS variadic but the caller declared it without prototype
+	bpf_printk("[debug]: %s", fmt);  // Real implementation would handle varargs
+}
+
 static __always_inline int tcp_lookup(void *ctx, struct header_pointers *hdr, bool xdp)
 {
 	struct bpf_ct_opts___local ct_lookup_opts = {
-- 
2.49.0

