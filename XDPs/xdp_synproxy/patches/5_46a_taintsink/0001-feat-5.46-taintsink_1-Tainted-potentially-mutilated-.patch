From a58c4fd64dbeb5cfc0e8aee8ed22a6ff78f2791c Mon Sep 17 00:00:00 2001
From: Francesco Rollo <eferollo@gmail.com>
Date: Wed, 16 Jul 2025 21:02:45 +0000
Subject: [PATCH] feat(5.46 taintsink_1): Tainted, potentially mutilated, or
 out-of-domain integer values are used in a restricted sink

Signed-off-by: Francesco Rollo <eferollo@gmail.com>
---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 41 +++++++++++++++++++++++++++
 1 file changed, 41 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..5175754 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -616,6 +616,47 @@ static __always_inline int syncookie_handle_syn(struct header_pointers *hdr,
 	if (hdr->tcp->fin || hdr->tcp->rst)
 		return XDP_DROP;
 
+	/*
+	 * Define a small, fixed-size array on the stack. Its size is
+	 * deliberately small (e.g., 32 bytes) to make out-of-bounds access
+	 * likely when indexed by a port number (which can be up to 65535).
+	 */
+	char policy_flags[32];
+
+	/*
+	 * Initialize the array to avoid "uninitialized stack read" warnings
+	 * from the verifier if any part of it is accessed within its bounds.
+	 * The loop is optimized away by the compiler into direct stack writes.
+	 */
+	#pragma unroll
+	for (int i = 0; i < sizeof(policy_flags); i++) {
+		policy_flags[i] = (char)i;
+	}
+
+	/*
+	 * Get a "tainted" integer value from the the destination port stored
+	 * in the packet header. This value comes directly from the untrusted
+	 * network packet.
+	 */
+	__u16 tainted_dest_port = bpf_ntohs(hdr->tcp->dest);
+
+	/*
+	 * Use the tainted `tainted_dest_port` directly as an array index into
+	 * `policy_flags` WITHOUT PROPER BOUNDS CHECKING.
+	 * The `tainted_dest_port` can be up to 65535, which is far beyond the
+	 * array's size (31 max index). This is the
+	 * "tainted value used in a restricted sink (array indexing)" violation.
+	 */
+	char accessed_flag_value = policy_flags[tainted_dest_port];
+
+	/*
+	 * The print here ensures the access is not optimized away, and forces
+	 * the verifier to analyze this specific instruction.
+	 */
+	bpf_printk("[taintsink]: Attempted access at index %u, value: %d",
+		tainted_dest_port,
+		accessed_flag_value);
+
 	/* Issue SYN cookies on allowed ports, drop SYN packets on blocked
 	 * ports.
 	 */
-- 
2.43.0

