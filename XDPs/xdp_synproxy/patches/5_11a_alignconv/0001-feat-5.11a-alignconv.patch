From 5ed470c47cf88920914870bc4bc6f8c89dc9e7eb Mon Sep 17 00:00:00 2001
From: Gianfranco Trad <gianf.trad@gmail.com>
Date: Fri, 29 Aug 2025 16:44:16 +0200
Subject: [PATCH] feat: 5.11a alignconv

Signed-off-by: Gianfranco Trad <gianf.trad@gmail.com>
---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..bb0fdd7 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -376,7 +376,15 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 	hdr->eth = data;
 	if (hdr->eth + 1 > data_end)
 		return XDP_DROP;
-
+	/* 
+       * UB Injection: Reading tcp_len as a stricter __u8 type.
+       * This results in undefined behavior because tcp_len is defined as __u16,
+       * and accessing it as a __u8 violates strict aliasing rules.
+    */
+    __u8 *tcp_len_as_u8 = (__u8 *)&hdr->tcp_len;
+    __u8 fake_tcp_len = *tcp_len_as_u8; 
+    if (fake_tcp_len == 0)
+        return XDP_DROP;
 	switch (bpf_ntohs(hdr->eth->h_proto)) {
 	case ETH_P_IP:
 		hdr->ipv6 = NULL;
-- 
2.43.0

