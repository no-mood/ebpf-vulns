From fb368ef59d06c3cab296c0d33f0a421f3d933c00 Mon Sep 17 00:00:00 2001
From: Gianfranco Trad <s323713@studenti.polito.it>
Date: Wed, 23 Jul 2025 12:55:00 +0000
Subject: [PATCH] feat(5.11 alignconv) Converting pointer values to more
 strictly aligned pointer types

---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..a27b896 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -421,7 +421,13 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 	hdr->tcp_len = hdr->tcp->doff * 4;
 	if (hdr->tcp_len < sizeof(*hdr->tcp))
 		return XDP_DROP;
-
+	
+	/* UB: misaligned pointer conversion (Rule 5.11 violation) */
+	char unaligned_buf[sizeof(struct iphdr) + 1];
+	char *unaligned_ptr = &unaligned_buf[1]; // intentionally unaligned
+	struct iphdr *misaligned_iph = (struct iphdr *)unaligned_ptr;
+	__u8 dummy_version = misaligned_iph->version; // triggers UB
+	
 	return XDP_TX;
 }
 
-- 
