From a24060fab50a839779a345e622ed029075592d0a Mon Sep 17 00:00:00 2001
From: Francesco Rollo <eferollo@gmail.com>
Date: Fri, 18 Jul 2025 13:12:38 +0000
Subject: [PATCH] feat(5.4 boolasgn): No assignment in conditional expressions

Signed-off-by: Francesco Rollo <eferollo@gmail.com>
---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 26 ++++++++++++++++++++++++++
 1 file changed, 26 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..cb5a789 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -610,6 +610,32 @@ static __always_inline int syncookie_handle_syn(struct header_pointers *hdr,
 	__u32 cookie;
 	__s64 value;
 
+	/*
+         * We'll use meaningful packet data: hdr->tcp_len and
+         * a local variable `processed_len`.
+         */
+
+    	__u16 processed_len = 0;
+    	/* Use hdr->tcp_len (actual TCP header length from the packet) */
+    	__u16 current_tcp_len = hdr->tcp_len;
+
+    	bpf_printk("[boolasgn]: Current tcp_len: %u", current_tcp_len);
+    	bpf_printk("[boolasgn]: Initial processed_len: %u", processed_len);
+
+    	/* 
+     	 * The assignment `processed_len = current_tcp_len` will always evaluate
+     	 * to the value of `current_tcp_len`. If `current_tcp_len` is non-zero,
+     	 * the condition is true, and the loop will enter. 
+	 * If it's zero, it won't.
+     	 */
+    	while (processed_len = current_tcp_len) {
+        	bpf_printk("[boolasgn]: processed_len is now: %u", processed_len);
+        	processed_len++;
+    	}
+
+    	/* It will never reach this */
+	bpf_printk("[boolasgn]: Final processed_len: %u", processed_len);
+
 	/* Checksum is not yet verified, but both checksum failure and TCP
 	 * header checks return XDP_DROP, so the order doesn't matter.
 	 */
-- 
