From 92f2127061944b9a6e431e7b55262c51d14269e0 Mon Sep 17 00:00:00 2001
From: Francesco Rollo <eferollo@gmail.com>
Date: Tue, 26 Aug 2025 10:41:01 +0000
Subject: [PATCH] feat(5.4 boolasgn_2): No assignment in conditional

Signed-off-by: Francesco Rollo <eferollo@gmail.com>
---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 17 +++++++++++++++++
 1 file changed, 17 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..37d4df5 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -610,6 +610,23 @@ static __always_inline int syncookie_handle_syn(struct header_pointers *hdr,
 	__u32 cookie;
 	__s64 value;
 
+	__u16 processed_len = 0;
+	__u16 current_tcp_len = hdr->tcp_len;
+
+	bpf_printk("[boolasgn]: Current tcp_len: %u", current_tcp_len);
+	bpf_printk("[boolasgn]: Initial processed_len: %u", processed_len);
+
+	/*
+	 * With do while, the body will run at least once.
+	 * The assignment happens in the while() condition.
+	 */
+	do {
+		bpf_printk("[boolasgn]: processed_len is now: %u", processed_len);
+		processed_len++;
+	} while (processed_len = current_tcp_len);
+	
+	bpf_printk("[boolasgn]: Final processed_len: %u", processed_len);
+
 	/* Checksum is not yet verified, but both checksum failure and TCP
 	 * header checks return XDP_DROP, so the order doesn't matter.
 	 */
-- 
