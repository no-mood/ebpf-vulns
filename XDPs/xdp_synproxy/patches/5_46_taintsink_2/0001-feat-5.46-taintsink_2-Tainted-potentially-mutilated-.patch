From bd2d1fc2af9574d73f2273bf318c1eff43ece975 Mon Sep 17 00:00:00 2001
From: Francesco Rollo <eferollo@gmail.com>
Date: Sat, 19 Jul 2025 10:11:16 +0000
Subject: [PATCH] feat(5.46 taintsink_2): Tainted, potentially mutilated, or
 out-of-domain integer values are used in a restricted sink

Signed-off-by: Francesco Rollo <eferollo@gmail.com>
---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 112 ++++++++++++++++++++++++++
 1 file changed, 112 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..1f32249 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -582,6 +582,19 @@ static __always_inline void tcpv6_gen_synack(struct header_pointers *hdr,
 	hdr->ipv6->payload_len = bpf_htons(hdr->tcp_len);
 }
 
+/* Helper function to print our buffers */
+static __always_inline void print_field(unsigned char *field, size_t len) {
+	size_t i;
+
+	if (field == NULL) {
+		return;
+	}
+
+	for (i = 0; i < len; i++) {
+		bpf_printk("[taintsink]: Value: 0x%x at idx %d", field[i], i);
+	}
+}
+
 static __always_inline int syncookie_handle_syn(struct header_pointers *hdr,
 						void *ctx,
 						void *data, void *data_end,
@@ -616,6 +629,105 @@ static __always_inline int syncookie_handle_syn(struct header_pointers *hdr,
 	if (hdr->tcp->fin || hdr->tcp->rst)
 		return XDP_DROP;
 
+	/*
+	 * NOTE: Variable Length Arrays (VLAs) are NOT supported in eBPF.
+	 * This example mimics the VLA vulnerability by using a fixed-size
+	 * buffer and a 'tainted' length for a memory copy operation.
+	 */
+
+	/*
+	 * 1. Choose a fixed-size buffer on the stack. For our test we can use
+	 *    hdr->eth->h_source (6 bytes) to ensure that a valid TCP
+	 *    header length (min 20 bytes, max 60 bytes for IPv4 TCP options)
+	 *    can easily exceed it.
+	 *
+	 *    NOTE: hdr->eth definition is:
+	 *
+	 *    struct ethhdr {
+	 *    	unsigned char h_dest[6];
+	 *    	unsigned char h_source[6];
+	 *    	__be16 h_proto;
+	 *    };
+	 *
+	 *    If we exceed the bound when writing on `h_dest` we should be able
+	 *    to verify that `h_source` and wathever comes next has been
+	 *    affected.
+	 *
+	 *    The BPF stack is allocated at fixed offsets. Declaring a
+	 *    tainted buffer and another variable immediately after doesn't
+	 *    ensure that we will be able to reach that variable when trying
+	 *    to write out of bound. For this reason we want to use a struct
+	 *    in order to intentionally place variables adjacently.
+	 */
+
+	/*
+	 * 2. Get a "tainted" integer value to use as a size.
+	 *    We'll use the TCP header's data offset (doff) to calculate the
+	 *    TCP header length. `hdr->tcp->doff` is a 4-bit field, so its value
+	 *    is 5-15. TCP Header Length = doff * 4 (range 20 to 60 bytes).
+	 */
+	__u32 tainted_length_from_packet = hdr->tcp->doff * 4;
+	bpf_printk("[taintsink]: Tainted length %u", tainted_length_from_packet);
+
+	/* Copy the MAC source address (6 bytes) */
+	unsigned char h_source_copy[6];
+	size_t h_source_size = sizeof(hdr->eth->h_source);
+        __builtin_memcpy(h_source_copy, hdr->eth->h_source, h_source_size);
+
+	bpf_printk("[taintsink]: Initial hdr->eth->h_source:");
+	print_field(hdr->eth->h_source, h_source_size);
+
+	/*
+	 * Loop through the tainted length to copy bytes.
+	 * The verifier will analyze this loop and detect the potential for `i`
+	 * to exceed `sizeof(hdr->eth->h_source)`'s bounds.
+	 */
+	__u32 i;
+	#pragma unroll
+	for (i = 0; i < tainted_length_from_packet; i++) {
+		/*
+		 * This condition is absolutely bogus and intentional to avoid
+		 * verifier's complaints. #pragma unroll is not working on this
+		 * particular case, so we want to declare an explit condition
+		 * by which the loop can be exited.
+		 * `h_proto` for IPv4 is 0x0800
+		 */
+		if (i > (h_source_size + hdr->eth->h_proto)) {
+			break;
+		}
+
+		/*
+		 * Writing to tainted_data_buffer[i]. This is the restricted
+		 * sink for the 'taintsink' rule. The index `i` can go up to 59,
+		 * while `tainted_data_buffer` only allows up to 31.
+		 * The verifier SHOULD reject the program due to this line.
+		 */
+		hdr->eth->h_dest[i] = i;
+		bpf_printk("[taintsink]: Wrote value %d at idx %d",
+				hdr->eth->h_dest[i],
+				i);
+	}
+
+	/*
+	 * If we reached the end of the loop, then we successfully wrote
+	 * out of bound. We can compare the initial h_source with the current
+	 * one, and verify that they actually differ.
+	 */
+	int cmp = __builtin_memcmp(hdr->eth->h_source,
+			h_source_copy,
+			h_source_size);
+	if (cmp != 0) {
+		bpf_printk("[taintsink]: hdr->eth->h_source differs: ");
+		print_field(hdr->eth->h_source, h_source_size);
+	}
+
+	bpf_printk("[taintsink]: End of loop reached (i: %d)", i);
+
+	/*
+	 * At this point our data is affected, so we expect an undefined
+	 * behaviour from our BPF!
+	 */
+
 	/* Issue SYN cookies on allowed ports, drop SYN packets on blocked
 	 * ports.
 	 */
-- 
2.43.0

