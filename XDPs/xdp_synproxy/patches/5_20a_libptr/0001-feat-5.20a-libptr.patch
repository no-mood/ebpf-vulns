From 9b88f68bac6ac28f416e06aa55ea784f6ab7f607 Mon Sep 17 00:00:00 2001
From: mood <74420740+no-mood@users.noreply.github.com>
Date: Sat, 30 Aug 2025 14:05:40 +0200
Subject: [PATCH] feat(5.20a libptr): forming invalid pointers by library
 function

---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 69 +++++++++++++++++++++++++++
 1 file changed, 69 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..d5759dc 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -1,6 +1,27 @@
 // SPDX-License-Identifier: LGPL-2.1 OR BSD-2-Clause
 /* Copyright (c) 2022, NVIDIA CORPORATION & AFFILIATES. All rights reserved. */
 
+/* PATCH 5.20a: Forming invalid pointers by library function - __builtin_memcpy [libptr]
+ *
+ * This patch demonstrates Rule 5.20a from ISO-IEC TS 17961-2013:
+ * "Invoking a C library function with an argument or arguments that causes the function to form
+ * a pointer that does not point into or just past the end of the object shall be diagnosed."
+ *
+ * VULNERABILITY DEMONSTRATION:
+ * Uses __builtin_memcpy with size parameter larger than destination buffer, causing the function
+ * to form invalid pointers beyond the allocated object boundaries during TCP options parsing.
+ *
+ * REALISTIC SCENARIO:
+ * During SYN proxy TCP options extraction, we parse variable-length TCP options (up to 40 bytes)
+ * into a fixed-size buffer. If buffer allocation is insufficient, __builtin_memcpy accesses
+ * memory beyond the allocated object when copying the full options length.
+ *
+ * RULE 5.20 COVERAGE:
+ * - Subpoint 5.20.2: Functions taking (dest_ptr, src_ptr, size_bytes)
+ * - Based on Example 1: allocated nchars bytes but memset with nchars+1
+ * - UB 109: Library function forms pointers beyond valid object boundaries
+ */
+
 #include "vmlinux.h"
 
 #include <bpf/bpf_helpers.h>
@@ -422,6 +443,54 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 	if (hdr->tcp_len < sizeof(*hdr->tcp))
 		return XDP_DROP;
 
+	/* 5.20a [libptr]: Invalid pointer formation by __builtin_memcpy
+	 *
+	 * VIOLATION: Using __builtin_memcpy with constant size larger than destination buffer.
+	 * Force buffer overflow by copying 24 bytes into 16-byte buffer, demonstrating how
+	 * __builtin_memcpy forms invalid pointers beyond allocated object boundaries.
+	 *
+	 * UB 109: __builtin_memcpy will form pointers beyond allocated object boundaries
+	 * when copying 24 bytes into tcp_options_small[16].
+	 *
+	 * **Implementation Details:**
+	 * - Buffer undersized: 16 bytes allocated vs 24 bytes copied
+	 * - __builtin_memcpy(dest, src, 24) forms invalid pointers when accessing dest[16-23]
+	 * - Based on Rule 5.20 Example 1: allocated nchars but used nchars+1 in memset
+	 * - Demonstrates classic library function parameter size error
+	 */
+	char tcp_options_small[16];  // UNDERSIZED: Only 16 bytes allocated
+	int tcp_opts_len = hdr->tcp_len - sizeof(*hdr->tcp);  // Actual TCP options length
+
+	// TCP options present and sufficient data available for forced copy
+	if (tcp_opts_len > 0) {
+		char *tcp_opts_ptr = (char *)hdr->tcp + sizeof(*hdr->tcp);
+
+		// Verify packet bounds for at least 24 bytes of options data
+		if (tcp_opts_ptr + 24 <= data_end) {
+
+			// RULE 5.20a VIOLATION: __builtin_memcpy with constant oversized copy
+			// Copy 24 bytes into 16-byte buffer - this is the violation!
+			// __builtin_memcpy will form invalid pointers when accessing:
+			// - tcp_options_small[0-15]: valid (within allocated object)
+			// - tcp_options_small[16-23]: INVALID (beyond object boundary)
+			__builtin_memcpy(tcp_options_small, tcp_opts_ptr, 24);  // diagnostic required
+
+			bpf_printk("[5.20a libptr]: FORCED COPY: 24 bytes into 16-byte buffer");
+			bpf_printk("[5.20a libptr]: __builtin_memcpy formed invalid pointers beyond boundary");
+
+			// Display first 4 bytes to show successful copy (before overflow)
+			bpf_printk("[5.20a libptr]: Valid options: %02x %02x %02x %02x",
+				   tcp_options_small[0], tcp_options_small[1],
+				   tcp_options_small[2], tcp_options_small[3]);
+
+			// This demonstrates the security risk: we wrote 8 bytes beyond buffer limit
+			bpf_printk("[5.20a libptr]: OVERFLOW: 8 bytes written beyond 16-byte buffer limit");
+
+		} else {
+			bpf_printk("[5.20a libptr]: Insufficient TCP options data for test");
+		}
+	}
+
 	return XDP_TX;
 }
 
