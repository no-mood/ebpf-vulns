From b4114c2bb29198e36922a3c66419fae5a86c1e90 Mon Sep 17 00:00:00 2001
From: Francesco Rollo <eferollo@gmail.com>
Date: Sun, 20 Jul 2025 15:05:55 +0000
Subject: [PATCH] feat(5.31 nonnullcs): Passing a non-null-terminated character

Signed-off-by: Francesco Rollo <eferollo@gmail.com>
---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 65 +++++++++++++++++++++++++++
 1 file changed, 65 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..508e429 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -616,6 +616,71 @@ static __always_inline int syncookie_handle_syn(struct header_pointers *hdr,
 	if (hdr->tcp->fin || hdr->tcp->rst)
 		return XDP_DROP;
 
+	/*
+	 * In this example we try to read data immediately after a defined
+	 * buffer. Since eBPF verifier often zero-initializes stack memory, we
+	 * explicitly place known, non-zero data after our target buffer to
+	 * demonstrate out-of-bounds read behavior.
+	 */
+
+	/* Define a struct to control memory layout on the stack.
+	 * It contains our small "string" buffer and then some explicitly
+	 * initialized non-zero fields directly following it.
+	 * The compiler will lay these out contiguously in memory.
+	 */
+	struct {
+		char string_buffer[8]; // 8 bytes target buffer
+		__u64 filler_data_1; // 8 bytes of known non-zero data
+		__u32 filler_data_2; // 4 bytes of known non-zero data
+		char padding_byte;   // 1 byte of filler, might be padded to alignment
+	} test_memory_layout;
+
+	/*
+	 * Initialize the entire struct to zero first.
+	 * This ensures any padding bytes are zero. -> Comment this out
+	 * to see if it does reads out of the struct bound.
+	 */
+	__builtin_memset(&test_memory_layout, 0, sizeof(test_memory_layout));
+
+	/*
+	 * Fill 'string_buffer' with non-null ASCII characters.
+	 * We deliberately do not null-terminate it.
+	 */
+	#pragma unroll
+	for (int i = 0; i < sizeof(test_memory_layout.string_buffer); i++) {
+		test_memory_layout.string_buffer[i] = (char)('A' + i);
+	}
+
+	/* Explicitly set the "filler" data to known non-zero values. */
+	test_memory_layout.filler_data_1 = 0xDEADBEEFDEADBEEFULL;
+	test_memory_layout.filler_data_2 = 0xCAFEBABEUL;
+	test_memory_layout.padding_byte = 0xCC;
+
+	bpf_printk("EBPF: --- Dumping test_memory_layout contents (hex) ---");
+	bpf_printk("EBPF: (Expected 'ABCDEFGH' followed by 0xDEADBEEFDEADBEEF,"
+		" 0xCAFEBABE, 0xCC and zeros)");
+
+	/*
+	 * Loop and print each byte of the entire struct as hex. This loop
+	 * will read beyond 'string_buffer' and into the 'filler_data' fields.
+	 * This avoids the '%s' null-termination check on purpose.
+	 * The size of the loop should be `sizeof(test_memory_layout)` to cover all data.
+	 */
+	#pragma unroll
+	for (int i = 0; i < sizeof(test_memory_layout); i++) {
+		char current_byte = *(((char *)&test_memory_layout) + i);
+		bpf_printk("  Offset %d: 0x%x", i, (unsigned char)current_byte);
+
+		/* Add a line break for every 8 bytes for readability */
+		if ((i + 1) % 8 == 0) {
+			bpf_printk("  ---");
+		}
+	}
+	bpf_printk("[nonnullcs]: --- End dump ---");
+
+	/* Try now to print as a C string with %s */
+	bpf_printk("[nonnullcs]: %s", test_memory_layout.string_buffer);
+
 	/* Issue SYN cookies on allowed ports, drop SYN packets on blocked
 	 * ports.
 	 */
-- 
