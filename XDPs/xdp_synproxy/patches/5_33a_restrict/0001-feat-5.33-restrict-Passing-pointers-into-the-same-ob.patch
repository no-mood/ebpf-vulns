From 946bf83b3cea9eb48ead96d5327afda20bffe37f Mon Sep 17 00:00:00 2001
From: Francesco Rollo <eferollo@gmail.com>
Date: Fri, 18 Jul 2025 11:34:36 +0000
Subject: [PATCH] feat(5.33 restrict): Passing pointers into the same object as
 arguments to different restrict-qualified parameters

Signed-off-by: Francesco Rollo <eferollo@gmail.com>
---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 108 ++++++++++++++++++++++++++
 1 file changed, 108 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..3c32cf3 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -520,7 +520,12 @@ static __always_inline void tcp_gen_synack(struct tcphdr *tcp_header,
 		tcp_flag_word(tcp_header) |= TCP_FLAG_ECE;
 	tcp_header->doff = 5; /* doff is part of tcp_flag_word. */
 	swap(tcp_header->source, tcp_header->dest);
+	bpf_printk("[restrict]: tcp->seq will affect the ack_seq, later forcing a retry");
 	tcp_header->ack_seq = bpf_htonl(bpf_ntohl(tcp_header->seq) + 1);
+	bpf_printk("[tcp_gen_synack]: tcp->seq is again set to cookie"
+			"([net order] before: %x, after: %x)",
+			tcp_header->seq,
+			bpf_htonl(cookie));
 	tcp_header->seq = bpf_htonl(cookie);
 	tcp_header->window = 0;
 	tcp_header->urg_ptr = 0;
@@ -582,6 +587,57 @@ static __always_inline void tcpv6_gen_synack(struct header_pointers *hdr,
 	hdr->ipv6->payload_len = bpf_htons(hdr->tcp_len);
 }
 
+/*
+ * This function explicitly violates the `restrict` contract when called 
+ * with aliasing pointers, leading to UB.
+ * When `restrict` is violated, the compiler, assuming non-aliasing, might
+ * optimize reads and writes in a way that leads to superseded data being 
+ * used.
+ */
+static __always_inline void
+simulate_restrict_ub(char *restrict read_ptr_base,
+                     char *restrict write_ptr_base,
+                     __u32 new_host_val)
+{
+	/* Convert the new value to network byte order for writing */
+	__be32 new_be_val = bpf_htonl(new_host_val);
+
+	/* Convert to host byte order for comparison/logic. */
+	__u32 initial_read_host_val = bpf_ntohl(get_unaligned((__be32 *)read_ptr_base));
+
+	/* 
+	* If `read_ptr_base` and `write_ptr_base` alias
+	* (which they will in our test call), this write will immediately
+	* modify the memory location that `read_ptr_base` points to.
+	*/
+	*(__be32 *)write_ptr_base = new_be_val;
+
+	/* 
+	* Due to `restrict`, the compiler might re-use the cached
+	* `initial_read_host_val`, assuming the data at `read_ptr_base`
+	* couldn't have changed via `write_ptr_base` because they are 
+	* `restrict`-qualified and thus non-aliasing.
+	*/
+	__u32 final_read_host_val = bpf_ntohl(get_unaligned((__be32 *)read_ptr_base));
+
+	bpf_printk("[restrict]: init read (host): %x, final read (host): %x,"
+		    " expected (host): %x",
+		    initial_read_host_val,
+		    final_read_host_val,
+		    new_host_val);
+
+	/* 
+	* If initial and final reads are the same, despite the explicit write,
+	* it's a strong symptom of the compiler exploiting the `restrict`
+	* contract, leading to a superseded read and demonstrating UB.
+	*/
+	if (initial_read_host_val == final_read_host_val) {
+		bpf_printk("[restrict]: *** UB Symptom Detected! ***");
+	} else {
+		bpf_printk("[restrict]: No UB symptom");
+	}
+}
+
 static __always_inline int syncookie_handle_syn(struct header_pointers *hdr,
 						void *ctx,
 						void *data, void *data_end,
@@ -662,6 +718,58 @@ static __always_inline int syncookie_handle_syn(struct header_pointers *hdr,
 		return XDP_ABORTED;
 	cookie = (__u32)value;
 
+	/*
+	 * We want to deliberately target `hdr->tcp->seq`, a critical field
+	 * from the incoming TCP packet that is *meant to be modified* by the
+	 * eBPF program (to become the syncookie in the outgoing SYN-ACK).
+	 *
+	 * We pass aliasing pointers (`&hdr->tcp->seq`) to 
+	 * `simulate_restrict_ub` which has `restrict`-qualified ptrs 
+	 * parameters. This violates the `restrict` contract.
+	 * The function reads `hdr->tcp->seq`, then explicitly writes the 
+	 * `cookie` value to it, and then attempts to read it again. Due to 
+	 * `restrict` assumptions, the compiler might incorrectly re-use a 
+	 * cached value, making the second read superseded and triggering UB.
+	 *
+	 * The outcome of this UB then can directly alter the packet's 
+	 * final processing decision. Even though the tcp->seq of the
+	 * generated synack will be the same, the now changed value will
+	 * affect the synack's ack_seq value, forcing a retry. 
+	 * NB: Check `tcp_gen_synack`
+	 */
+
+	/* Make a copy for comparison check */
+	__u32 tcp_seq_copy = hdr->tcp->seq;
+
+	/* 
+	 * `read_ptr_base` and `write_ptr_base` both point to the memory 
+	 * location of `hdr->tcp->seq`. The `new_host_val` is the `cookie` 
+	 * (the value `hdr->tcp->seq` will eventually become).
+	 */
+	simulate_restrict_ub((char *)&hdr->tcp->seq,
+			(char *)&hdr->tcp->seq,
+			cookie);
+
+	/* 
+	 * After `simulate_restrict_ub` returns, `hdr->tcp->seq` will 
+	 * now contain `bpf_htonl(cookie)` due to the write inside the helper.
+	 * The original `syncookie_handle_syn` logic would eventually overwrite
+	 * it with `bpf_htonl(cookie)` again in `tcp_gen_synack`, so this 
+	 * MAY not break the final packet, but the UB test has operated on this
+	 * critical field. In this case MAY becomes WILL because the synack's 
+	 * ack_seq will be affected. 
+	 */
+
+	bpf_printk("[restrict]: hdr->tcp->seq is now %x "
+			"(stored in net order, printed in host order)", 
+			bpf_ntohl(hdr->tcp->seq));
+
+	if (tcp_seq_copy != hdr->tcp->seq) {
+		bpf_printk("[restrict]: tcp_seq has changed but"
+				" `simulate_restrict_ub` treated it as"
+				" unchanged even after write");
+	}
+
 	if (tscookie_init((void *)hdr->tcp, hdr->tcp_len,
 			  &tsopt_buf[0], &tsopt_buf[1], data, data_end))
 		tsopt = tsopt_buf;
-- 
2.43.0

