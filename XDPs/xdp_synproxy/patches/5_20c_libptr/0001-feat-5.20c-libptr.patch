From e511a5c0da6a4c7fb8f588430c4c11acdea706e3 Mon Sep 17 00:00:00 2001
From: mood <74420740+no-mood@users.noreply.github.com>
Date: Sat, 30 Aug 2025 14:23:57 +0200
Subject: [PATCH] feat(5.20c libptr): forming invalid pointers by library
 function

---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 77 +++++++++++++++++++++++++++
 1 file changed, 77 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..f42e9f0 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -1,6 +1,27 @@
 // SPDX-License-Identifier: LGPL-2.1 OR BSD-2-Clause
 /* Copyright (c) 2022, NVIDIA CORPORATION & AFFILIATES. All rights reserved. */
 
+/* PATCH 5.20c: Forming invalid pointers by library function - Packet data size calculations [libptr]
+ *
+ * This patch demonstrates Rule 5.20c from ISO-IEC TS 17961-2013:
+ * "Invoking a C library function with an argument or arguments that causes the function to form
+ * a pointer that does not point into or just past the end of the object shall be diagnosed."
+ *
+ * VULNERABILITY DEMONSTRATION:
+ * Uses __builtin_memcpy with incorrect size calculations based on wrong type assumptions,
+ * causing the function to form invalid pointers when accessing packet data beyond boundaries.
+ *
+ * REALISTIC SCENARIO:
+ * During SYN proxy packet processing, we calculate buffer sizes using wrong data types
+ * (e.g., sizeof(int) instead of sizeof(char) in multiplications), leading to oversized
+ * copy operations that exceed packet data or buffer boundaries.
+ *
+ * RULE 5.20 COVERAGE:
+ * - Subpoint 5.20.2: Functions taking (dest_ptr, src_ptr, size_bytes)
+ * - Based on Example 2: sizeof(int) vs sizeof(float) type size confusion
+ * - UB 109: __builtin_memcpy forms pointers beyond valid packet/buffer boundaries
+ */
+
 #include "vmlinux.h"
 
 #include <bpf/bpf_helpers.h>
@@ -422,6 +443,62 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 	if (hdr->tcp_len < sizeof(*hdr->tcp))
 		return XDP_DROP;
 
+	/* 5.20c [libptr]: Invalid pointer formation by wrong size calculations
+	 *
+	 * VIOLATION: Using __builtin_memcpy with size calculated using wrong data type assumptions.
+	 * Demonstrates type size confusion where sizeof(int) is used instead of sizeof(char)
+	 * in size calculations, leading to oversized copy operations.
+	 *
+	 * UB 109: __builtin_memcpy will form pointers beyond allocated object boundaries
+	 * when copying wrong_size bytes into packet_analysis_buffer[20].
+	 *
+	 * **Implementation Details:**
+	 * - Buffer sized: 20 bytes allocated for packet analysis
+	 * - Size calculation error: sizeof(int) * 8 = 32 bytes instead of sizeof(char) * 8 = 8 bytes
+	 * - __builtin_memcpy(dest, src, wrong_size) forms invalid pointers when wrong_size > dest_size
+	 * - Based on Rule 5.20 Example 2: sizeof(int) vs sizeof(float) type confusion
+	 * - Demonstrates realistic packet processing size calculation errors
+	 */
+	char packet_analysis_buffer[20];  // Buffer for packet data analysis
+
+	// Calculate packet data length for analysis (this is correct)
+	size_t packet_data_len = (char *)data_end - (char *)data;
+
+	// Verify we have sufficient packet data and reasonable length
+	if (packet_data_len > 8 && packet_data_len < 1500) {
+
+		// RULE 5.20c VIOLATION: Wrong type in size calculation
+		// We want to copy 8 bytes, but mistakenly calculate using sizeof(int) instead of sizeof(char)
+		// This assumes int-sized elements when packet data is byte-oriented
+		size_t wrong_size = sizeof(int) * 8;  // 32 bytes instead of 8 bytes!
+
+		// Verify we have enough packet data for the (wrong) size calculation
+		if ((char *)data + wrong_size <= data_end) {
+
+			// RULE 5.20c VIOLATION: __builtin_memcpy with type-confused size calculation
+			// Copy 32 bytes into 20-byte buffer due to sizeof(int) vs sizeof(char) confusion
+			// __builtin_memcpy will form invalid pointers when accessing:
+			// - packet_analysis_buffer[0-19]: valid (within allocated object)
+			// - packet_analysis_buffer[20-31]: INVALID (beyond object boundary)
+			__builtin_memcpy(packet_analysis_buffer, data, wrong_size);  // diagnostic required
+
+			bpf_printk("[5.20c libptr]: TYPE CONFUSION: used sizeof(int)*8 = %zu instead of sizeof(char)*8", wrong_size);
+			bpf_printk("[5.20c libptr]: __builtin_memcpy formed invalid pointers beyond boundary");
+
+			// Display first few bytes to show successful partial copy
+			bpf_printk("[5.20c libptr]: Packet data: %02x %02x %02x %02x",
+				   packet_analysis_buffer[0], packet_analysis_buffer[1],
+				   packet_analysis_buffer[2], packet_analysis_buffer[3]);
+
+			// This demonstrates the security risk: wrong size calculation led to buffer overflow
+			bpf_printk("[5.20c libptr]: OVERFLOW: %zu bytes written beyond 20-byte buffer limit",
+				   wrong_size - 20);
+
+		} else {
+			bpf_printk("[5.20c libptr]: Insufficient packet data for wrong size test");
+		}
+	}
+
 	return XDP_TX;
 }
 
