From 79ba5ae053a1245e35dfe947d9ec20c4882c419c Mon Sep 17 00:00:00 2001
From: mood <74420740+no-mood@users.noreply.github.com>
Date: Sat, 30 Aug 2025 14:18:25 +0200
Subject: [PATCH] feat(5.20b libptr): forming invalid pointers by library
 function

---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 69 +++++++++++++++++++++++++++
 1 file changed, 69 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..150a824 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -1,6 +1,27 @@
 // SPDX-License-Identifier: LGPL-2.1 OR BSD-2-Clause
 /* Copyright (c) 2022, NVIDIA CORPORATION & AFFILIATES. All rights reserved. */
 
+/* PATCH 5.20b: Forming invalid pointers by library function - BPF helpers [libptr]
+ *
+ * This patch demonstrates Rule 5.20b from ISO-IEC TS 17961-2013:
+ * "Invoking a C library function with an argument or arguments that causes the function to form
+ * a pointer that does not point into or just past the end of the object shall be diagnosed."
+ *
+ * VULNERABILITY DEMONSTRATION:
+ * Uses BPF helper functions with size parameters larger than destination buffers, causing the
+ * helpers to form invalid pointers beyond allocated object boundaries during memory operations.
+ *
+ * REALISTIC SCENARIO:
+ * During SYN proxy packet processing, we use BPF helpers like bpf_probe_read_kernel to extract
+ * data from kernel structures into local buffers. If buffer sizing is incorrect, helpers
+ * attempt to write beyond the allocated buffer boundaries.
+ *
+ * RULE 5.20 COVERAGE:
+ * - Subpoint 5.20.1: Functions taking (pointer, size_bytes)
+ * - Based on Example 1: helper tries to write size bytes into smaller buffer
+ * - UB 109: BPF helper forms pointers beyond valid buffer boundaries
+ */
+
 #include "vmlinux.h"
 
 #include <bpf/bpf_helpers.h>
@@ -422,6 +443,54 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 	if (hdr->tcp_len < sizeof(*hdr->tcp))
 		return XDP_DROP;
 
+	/* 5.20b [libptr]: Invalid pointer formation by BPF helper functions
+	 *
+	 * VIOLATION: Using BPF helpers with size parameter larger than destination buffer.
+	 * BPF helpers like bpf_probe_read_kernel take (dest_ptr, size, src_ptr) parameters,
+	 * and will form invalid pointers when size exceeds the destination buffer bounds.
+	 *
+	 * UB 109: bpf_probe_read_kernel will form pointers beyond allocated object boundaries
+	 * when writing 32 bytes into kernel_data_small[12].
+	 *
+	 * **Implementation Details:**
+	 * - Buffer undersized: 12 bytes allocated vs 32 bytes requested
+	 * - bpf_probe_read_kernel(dest, size, src) forms invalid pointers when size > dest_size
+	 * - Based on Rule 5.20 Example 1: buffer smaller than operation size
+	 * - Demonstrates BPF helper parameter size error leading to buffer overflow
+	 */
+	char kernel_data_small[12];  // UNDERSIZED: Only 12 bytes allocated
+
+	// Use TCP header as source for "kernel data" extraction
+	void *tcp_header_ptr = (void *)hdr->tcp;
+
+	// Verify we have sufficient packet data for the helper operation
+	if (tcp_header_ptr + 32 <= data_end) {
+
+		// RULE 5.20b VIOLATION: bpf_probe_read_kernel with oversized buffer operation
+		// Request 32 bytes into 12-byte buffer - this is the violation!
+		// bpf_probe_read_kernel will form invalid pointers when accessing:
+		// - kernel_data_small[0-11]: valid (within allocated object)
+		// - kernel_data_small[12-31]: INVALID (beyond object boundary)
+		long ret = bpf_probe_read_kernel(kernel_data_small, 32, tcp_header_ptr);  // diagnostic required
+
+		bpf_printk("[5.20b libptr]: bpf_probe_read_kernel returned: %ld", ret);
+		bpf_printk("[5.20b libptr]: FORCED READ: 32 bytes into 12-byte buffer");
+		bpf_printk("[5.20b libptr]: BPF helper formed invalid pointers beyond boundary");
+
+		// Display first 4 bytes to show partial success (before overflow)
+		if (ret == 0) {
+			bpf_printk("[5.20b libptr]: Valid data: %02x %02x %02x %02x",
+				   kernel_data_small[0], kernel_data_small[1],
+				   kernel_data_small[2], kernel_data_small[3]);
+		}
+
+		// This demonstrates the security risk: helper wrote 20 bytes beyond buffer limit
+		bpf_printk("[5.20b libptr]: OVERFLOW: 20 bytes written beyond 12-byte buffer limit");
+
+	} else {
+		bpf_printk("[5.20b libptr]: Insufficient packet data for BPF helper test");
+	}
+
 	return XDP_TX;
 }
 
