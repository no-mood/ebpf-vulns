From 75265c21a56404023dd54317c6d55b40d011b4e9 Mon Sep 17 00:00:00 2001
From: Francesco Rollo <eferollo@gmail.com>
Date: Sun, 27 Jul 2025 15:54:16 +0000
Subject: [PATCH] feat(5.46 taintsink_3): Tainted, potentially mutilated, or
 out-of-domain integer values are used in a restricted sink

Signed-off-by: Francesco Rollo <eferollo@gmail.com>
---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 14 ++++++++++++++
 1 file changed, 14 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..532ff14 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -615,7 +615,21 @@ static __always_inline int syncookie_handle_syn(struct header_pointers *hdr,
 	 */
 	if (hdr->tcp->fin || hdr->tcp->rst)
 		return XDP_DROP;
+	/*
+	 * IMPORTANT: Variable Length Arrays (VLAs) are NOT SUPPORTED in eBPF.
+	 * This code is included purely to demonstrate that the eBPF verifier
+	 * will reject programs containing VLAs because eBPF requires all
+	 * stack allocations to have a compile-time fixed size.
+	 *
+	 * We'll use a packet field (TCP Data Offset * 4) as a 'tainted' size.
+	 */
+	__u32 tainted_vla_size = hdr->tcp->doff * 4;
+	char vla_buffer[tainted_vla_size];
 
+	/* Ensure the VLA is not optimized away */
+	bpf_printk("[taintsink_vla]: VLA size attempted: %u, first byte: 0x%x",
+		tainted_vla_size, vla_buffer[0]);
+	
 	/* Issue SYN cookies on allowed ports, drop SYN packets on blocked
 	 * ports.
 	 */
