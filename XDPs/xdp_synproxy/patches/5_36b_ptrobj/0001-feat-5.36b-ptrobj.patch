From bafddece6083b1bd195357617c141f310f6785d7 Mon Sep 17 00:00:00 2001
From: mood <74420740+no-mood@users.noreply.github.com>
Date: Tue, 22 Jul 2025 19:32:33 +0200
Subject: [PATCH] feat(5.36b ptrobj): Subtracting or relationally comparing two
 pointers that do not refer to the same array object, or one element past the
 same array object, shall be diagnosed. The relational operators are >, <, >=,
 and <=.

---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 76 +++++++++++++++++++++++++--
 1 file changed, 73 insertions(+), 3 deletions(-)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..8d2d03d 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -1,6 +1,29 @@
 // SPDX-License-Identifier: LGPL-2.1 OR BSD-2-Clause
 /* Copyright (c) 2022, NVIDIA CORPORATION & AFFILIATES. All rights reserved. */
 
+/* PATCH 5.36b: Subtracting or comparing pointers from different array objects [ptrobj] - Context Pointers Case
+ *
+ * This patch demonstrates Rule 5.36 from ISO-IEC TS 17961-2013:
+ * "Subtracting or relationally comparing two pointers that do not refer to the same array object,
+ * or one element past the same array object, shall be diagnosed."
+ *
+ * VULNERABILITY DEMONSTRATION - CONTEXT POINTERS vs PACKET DATA:
+ * This specific test focuses on violations between:
+ * 1. XDP context structure pointers (ctx metadata)
+ * 2. Packet data pointers (network buffer from ctx->data)
+ * 3. Different fields within the XDP context (data_meta vs data)
+ *
+ * The bug: accidentally comparing/subtracting pointers from the XDP context structure
+ * with packet data pointers, treating them as if they're in the same memory object.
+ *
+ * REALISTIC SCENARIO:
+ * During XDP packet processing, mistakenly perform arithmetic between the context
+ * structure itself and packet data, or between different context pointer fields.
+ *
+ * EXPECTED eBPF VERIFIER BEHAVIOR:
+ * Should diagnose pointer operations between context structure and packet buffer objects.
+ */
+
 #include "vmlinux.h"
 
 #include <bpf/bpf_helpers.h>
@@ -370,9 +393,17 @@ struct header_pointers {
 	__u16 tcp_len;
 };
 
-static __always_inline int tcp_dissect(void *data, void *data_end,
-				       struct header_pointers *hdr)
+/* VULNERABLE FUNCTION - Rule 5.36: Minimal demonstration of cross-object pointer arithmetic
+ *
+ * This function shows the simplest case: comparing and subtracting pointers from
+ * different objects (packet data vs. local stack array).
+ */
+static __always_inline int tcp_dissect(void *ctx, void *data, void *data_end,
+			       struct header_pointers *hdr)
 {
+	/* XDP context - this is OBJECT 1 (context structure) */
+	struct xdp_md *xdp_ctx = (struct xdp_md *)ctx;
+
 	hdr->eth = data;
 	if (hdr->eth + 1 > data_end)
 		return XDP_DROP;
@@ -422,6 +453,45 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 	if (hdr->tcp_len < sizeof(*hdr->tcp))
 		return XDP_DROP;
 
+	/* VULNERABILITY 1: Compare XDP context pointer with packet data pointer
+	 * xdp_ctx points to context structure (OBJECT 1: XDP metadata)
+	 * data points to packet buffer (OBJECT 2: network buffer)
+	 * These are COMPLETELY DIFFERENT objects! */
+	if ((void *)xdp_ctx > data) { // diagnostic required - different memory objects!
+		bpf_printk("5.36b CTX: XDP context %p > packet data %p", xdp_ctx, data);
+
+		/* VULNERABILITY 2: Subtract context pointer from packet pointer
+		 * This calculation is UNDEFINED BEHAVIOR! */
+		ptrdiff_t ctx_distance = (char *)data - (char *)xdp_ctx; // diagnostic required
+		bpf_printk("5.36b CTX: Distance ctx->packet: %td", ctx_distance);
+
+		/* VULNERABILITY 3: Compare context with packet end boundary */
+		if ((void *)xdp_ctx < data_end) { // diagnostic required
+			bpf_printk("5.36b CTX: context %p < packet_end %p", xdp_ctx, data_end);
+		}
+
+		/* DANGER: Use undefined result in program logic */
+		if (ctx_distance > 0) { // Undefined behavior in conditional!
+			bpf_printk("5.36b CRITICAL: XDP logic based on undefined pointer arithmetic!");
+		}
+	}
+
+	/* VULNERABILITY 4: data_meta vs data comparison (different context fields)
+	 * Both are from XDP context but may point to different memory regions */
+	void *meta_start = (void *)(long)xdp_ctx->data_meta;
+	void *data_start = (void *)(long)xdp_ctx->data;
+
+	if (meta_start != data_start) { // This comparison itself is valid
+		/* VIOLATION: But subtract pointers from potentially different objects */
+		ptrdiff_t meta_distance = (char *)data_start - (char *)meta_start; // diagnostic required if different objects
+		bpf_printk("5.36b META: Distance meta->data: %td", meta_distance);
+
+		/* VIOLATION: Compare packet data with metadata area */
+		if (meta_start > data) { // diagnostic required if different objects
+			bpf_printk("5.36b META: metadata %p > packet %p", meta_start, data);
+		}
+	}
+
 	return XDP_TX;
 }
 
@@ -758,7 +828,7 @@ static __always_inline int syncookie_part1(void *ctx, void *data, void *data_end
 {
 	int ret;
 
-	ret = tcp_dissect(data, data_end, hdr);
+	ret = tcp_dissect(ctx, data, data_end, hdr);
 	if (ret != XDP_TX)
 		return ret;
 
-- 
