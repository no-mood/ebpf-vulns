From 5b64485af47bb021a7d8ce010d01a2487c56add2 Mon Sep 17 00:00:00 2001
From: Gianfranco Trad <s323713@studenti.polito.it>
Date: Wed, 23 Jul 2025 12:50:13 +0000
Subject: [PATCH] feat(5.1 ptrcomp): Accessing an object through a pointer to
 an incompatible type

---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..9e28e3d 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -377,6 +377,11 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 	if (hdr->eth + 1 > data_end)
 		return XDP_DROP;
 
+	
+	/* UB injection: reinterpret Ethernet header as IPv4 header */
+	struct iphdr *fake_ipv4 = (struct iphdr *)hdr->eth;
+	__u8 ttl = fake_ipv4->ttl; // UB: accessing IP header fields from eth pointer
+
 	switch (bpf_ntohs(hdr->eth->h_proto)) {
 	case ETH_P_IP:
 		hdr->ipv6 = NULL;
-- 
2.43.0

