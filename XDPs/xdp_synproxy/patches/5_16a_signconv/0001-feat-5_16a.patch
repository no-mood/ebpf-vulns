From d805182f0d6283adf4dd76546ed811b474719209 Mon Sep 17 00:00:00 2001
From: mood <74420740+no-mood@users.noreply.github.com>
Date: Wed, 23 Jul 2025 19:37:50 +0200
Subject: [PATCH] feat(5.16a signconv): Converting a tainted value of type char
 or signed char to a larger integer type without having first cast the value
 to unsigned char shall be diagnosed if the value is subsequently compared
 with the value of EOF.

---
 XDPs/xdp_synproxy/xdp_synproxy_kern.c | 28 +++++++++++++++++++++++++++
 1 file changed, 28 insertions(+)

diff --git a/XDPs/xdp_synproxy/xdp_synproxy_kern.c b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
index 0d0d990..7372a29 100644
--- a/XDPs/xdp_synproxy/xdp_synproxy_kern.c
+++ b/XDPs/xdp_synproxy/xdp_synproxy_kern.c
@@ -7,6 +7,8 @@
 #include <bpf/bpf_endian.h>
 #include <asm/errno.h>
 
+#define EOF (-1) // We can't import <stdio.h> in BPF programs, so we define EOF manually
+
 #define TC_ACT_OK 0
 #define TC_ACT_SHOT 2
 
@@ -422,6 +424,32 @@ static __always_inline int tcp_dissect(void *data, void *data_end,
 	if (hdr->tcp_len < sizeof(*hdr->tcp))
 		return XDP_DROP;
 
+	// --- ISO-IEC TS 17961-2013 Rule 5.16a Example: SIGN CONVERSION (RAW VERSION) ---
+	// Vulnerability: Converting signed char to int without unsigned cast before EOF comparison
+	// UB: If char is signed, 0xFF char is sign-extended to -1 (EOF), causing false positive
+	//
+	// This version directly accesses tainted TCP payload data without verifier workarounds.
+	// Expected to FAIL verifier due to unbounded memory access of network data.
+
+	// Direct access to TCP payload (tainted data) - likely to fail verifier
+	char *tcp_payload = (char *)hdr->tcp + (hdr->tcp->doff * 4);
+
+	// Process first few bytes of payload without proper bounds checking
+	for (int i = 0; i < 4; i++) {
+		// VIOLATION: Direct access to tainted network data
+		char raw_char = tcp_payload[i];  // verifier should reject this
+
+		// VIOLATION: signed char to int conversion without unsigned cast
+		int c = raw_char;  // 0xFF becomes -1 instead of 255
+
+		// The problematic EOF check - 0xFF chars will be confused with EOF
+		if (c == EOF) {  // diagnostic required - false positive on 0xFF
+			bpf_printk("[5.16a signconv]: False EOF detected at pos %d", i);
+		}
+
+		bpf_printk("[5.16a signconv]: Raw char %d: signed=%d", i, c);
+	}
+
 	return XDP_TX;
 }
 
-- 
